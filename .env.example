INSTANCE_NAME=tailnord

# IP addresses for the containers
IP_SUBNET="10.1.1.0/24"
IP_TAILSCALE="10.1.1.2"
IP_NORDVPN="10.1.1.3"
IP_PANEL="10.1.1.4"

# Your Tailscale information
TAILSCALE_AUTH_KEY=
TAILSCALE_UP_LOGIN_SERVER=

# Your NordVPN login token
NORDVPN_TOKEN=

# Which endpoint to connect to
NORDVPN_ENDPOINT=San_Francisco

# If using the regular NordVPN client
NORDVPN_TECHNOLOGY=openvpn
NORDVPN_OPENVPN_PROTOCOL=tcp

# Disconnect and reconnect after N hours
NORDVPN_RECONNECT_AFTER_HOURS=168

# ProtonVPN — required only when running the protonvpn service.
# Populate protonvpn/wireguard/ first (see README — ProtonVPN first-time setup).
#IP_PROTONVPN="10.1.1.5"
#IP_SUBNET_V6="fd00:cafe:1::/64"
#IP_VPN_V6="fd00:cafe:1::10"
# Override the default startup config (US/San_Jose/us-ca_10.conf):
#PROTONVPN_WG_CONF=/etc/wireguard/US/San_Jose/us-ca_10.conf
